<UserControl x:Class="RezepturMeister.Views.RohstoffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RezepturMeister.Views"
             xmlns:vm="clr-namespace:RezepturMeister.ViewModels"
             xmlns:conv="clr-namespace:RezepturMeister.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:DecimalConverter x:Key="DecimalConverter" />
        <conv:NullableDoubleConverter x:Key="NullableDoubleConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </UserControl.Resources>
    <UserControl.DataContext>
        <vm:RohstoffViewModel />
    </UserControl.DataContext>
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="10,8,10,8">
                <Button Command="{Binding AddRohstoffCommand}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource BtnIcon}" Text="&#xE710;"/>
                        <TextBlock Style="{StaticResource BtnLabel}" Text="Hinzufügen"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding EditRohstoffCommand}" Margin="0,0,8,0"
                        Style="{StaticResource SaveButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource BtnIcon}" Text="&#xE74E;"/>
                        <TextBlock Style="{StaticResource BtnLabel}" Text="Speichern"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding DeleteRohstoffCommand}"
                        Style="{StaticResource DangerButton}" Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource BtnIcon}" Text="&#xE74D;"/>
                        <TextBlock Style="{StaticResource BtnLabel}" Text="Löschen"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenDatenblattCommand}" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        ToolTip="Verlinktes PDF/XLSX öffnen">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource BtnIcon}" Text="&#xE8B9;"/>
                        <TextBlock Style="{StaticResource BtnLabel}" Text="Datenblatt öffnen"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding LinkDatenblattCommand}" Margin="0,0,20,0"
                        Style="{StaticResource SecondaryButton}"
                        ToolTip="PDF oder XLSX mit diesem Rohstoff verknüpfen">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource BtnIcon}" Text="&#xE71B;"/>
                        <TextBlock Style="{StaticResource BtnLabel}" Text="Datenblatt verknüpfen"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportPdfCommand}" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource BtnIcon}" Text="&#xE8A5;"/>
                        <TextBlock Style="{StaticResource BtnLabel}" Text="Export PDF"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportXlsxCommand}" Margin="0,0,20,0"
                        Style="{StaticResource SecondaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource BtnIcon}" Text="&#xE9D2;"/>
                        <TextBlock Style="{StaticResource BtnLabel}" Text="Export Excel"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ImportNaehrwerteCSVCommand}"
                        Style="{StaticResource SecondaryButton}"
                        ToolTip="Nährwertdaten aus CSV-Datei importieren&#x0a;Format: Name;Energie_kJ;Energie_kcal;Fett;GesaettigteFettsaeuren;Kohlenhydrate;Zucker;Ballaststoffe;Eiweiss;Salz">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource BtnIcon}" Text="&#xE8D6;"/>
                        <TextBlock Style="{StaticResource BtnLabel}" Text="Nährwerte CSV importieren"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,10,5">
            <TextBlock Text="Suche:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Text="{Binding SuchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="250" VerticalAlignment="Center"
                     ToolTip="Nach Name oder Kategorie filtern"/>
            <Button Command="{Binding ClearSuchTextCommand}"
                    Margin="5,0,0,0" Padding="6,2" ToolTip="Filter zurücksetzen">
                <TextBlock Style="{StaticResource BtnIcon}" Text="&#xE8BB;" Margin="0"/>
            </Button>
        </StackPanel>
        <DataGrid Grid.Row="2" Margin="10,5,10,5"
                  ItemsSource="{Binding RohstoffeView}"
                  SelectedItem="{Binding SelectedRohstoff}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Kategorie" Binding="{Binding Kategorie}" Width="100"/>
                <DataGridTextColumn Header="Dichte (g/ml)" Binding="{Binding Dichte, Converter={StaticResource DecimalConverter}}" Width="100"/>
                <DataGridTextColumn Header="Alkohol (%)" Binding="{Binding Alkoholgehalt, Converter={StaticResource DecimalConverter}}" Width="90"/>
                <DataGridTextColumn Header="Preis (€/kg o. l)" Binding="{Binding Preis, StringFormat=F2}" Width="110"/>
                <DataGridTextColumn Header="Lieferant" Binding="{Binding Lieferant}" Width="120"/>
                <DataGridTextColumn Header="Datenblatt" Binding="{Binding DatenblattPfad}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
        <!-- Nährwertdaten des ausgewählten Rohstoffs (pro 100 g) -->
        <Expander Grid.Row="3" Margin="10,0,10,10" IsExpanded="False"
                  Visibility="{Binding SelectedRohstoff, Converter={StaticResource NullToVisibilityConverter}}">
            <Expander.Header>
                <TextBlock>
                    <Run Text="Nährwertdaten pro 100 g — "/>
                    <Run Text="{Binding SelectedRohstoff.Name, FallbackValue=''}"/>
                    <Run Text="  " FontSize="9" Foreground="Gray"/>
                    <Run Text="(Speichern nicht vergessen)" FontSize="9" Foreground="Gray"/>
                </TextBlock>
            </Expander.Header>
            <Grid Margin="4,6,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Spalte 0 -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,3">
                    <TextBlock Text="Brennwert (kJ):" Width="125" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedRohstoff.Energie_kJ, Converter={StaticResource NullableDoubleConverter}}" Width="75"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,3">
                    <TextBlock Text="Brennwert (kcal):" Width="125" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedRohstoff.Energie_kcal, Converter={StaticResource NullableDoubleConverter}}" Width="75"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,3">
                    <TextBlock Text="Eiweiß (g):" Width="125" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedRohstoff.Eiweiss, Converter={StaticResource NullableDoubleConverter}}" Width="75"/>
                </StackPanel>

                <!-- Spalte 1 -->
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="8,3">
                    <TextBlock Text="Fett (g):" Width="145" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedRohstoff.Fett, Converter={StaticResource NullableDoubleConverter}}" Width="75"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="8,3">
                    <TextBlock Text="ges. Fettsäuren (g):" Width="145" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedRohstoff.GesaettigteFettsaeuren, Converter={StaticResource NullableDoubleConverter}}" Width="75"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="8,3">
                    <TextBlock Text="Ballaststoffe (g):" Width="145" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedRohstoff.Ballaststoffe, Converter={StaticResource NullableDoubleConverter}}" Width="75"/>
                </StackPanel>

                <!-- Spalte 2 -->
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="8,3">
                    <TextBlock Text="Kohlenhydrate (g):" Width="140" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedRohstoff.Kohlenhydrate, Converter={StaticResource NullableDoubleConverter}}" Width="75"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="8,3">
                    <TextBlock Text="davon Zucker (g):" Width="140" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedRohstoff.Zucker, Converter={StaticResource NullableDoubleConverter}}" Width="75"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" Margin="8,3">
                    <TextBlock Text="Salz (g):" Width="140" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedRohstoff.Salz, Converter={StaticResource NullableDoubleConverter}}" Width="75"/>
                </StackPanel>
            </Grid>
        </Expander>
    </Grid>
</UserControl>