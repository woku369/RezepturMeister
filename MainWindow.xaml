<Window x:Class="RezepturMeister.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RezepturMeister"
        xmlns:views="clr-namespace:RezepturMeister.Views"
        xmlns:vm="clr-namespace:RezepturMeister.ViewModels"
        mc:Ignorable="d"
        Title="RezepturMeister" Height="660" Width="1020"
        Background="#F8F6F2"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- App-Header -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0F2444" Offset="0"/>
                    <GradientStop Color="#1E3F6F" Offset="0.6"/>
                    <GradientStop Color="#16305A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="3"/>
                </Grid.RowDefinitions>
                <DockPanel Margin="18,10,18,8" LastChildFill="False">
                    <!-- Logo links -->
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Rezeptur"
                                       FontFamily="{StaticResource BrandFont}"
                                       FontSize="28" FontWeight="Normal"
                                       Foreground="White" VerticalAlignment="Bottom"/>
                            <TextBlock Text="Meister"
                                       FontFamily="{StaticResource BrandFont}"
                                       FontSize="28" FontWeight="Normal"
                                       Foreground="#C8922A" VerticalAlignment="Bottom"
                                       Margin="6,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="Rezepturen für alkoholische Getränke"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="Normal"
                                   Foreground="#8AAFD4" Margin="2,2,0,0"/>
                    </StackPanel>
                    <!-- Hilfe-Button rechts -->
                    <Button DockPanel.Dock="Right" VerticalAlignment="Center"
                            Style="{StaticResource HeaderButton}"
                            Click="HelpButton_Click"
                            ToolTip="Benutzerhandbuch öffnen (F1)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource BtnIcon}" Text="&#xE897;" FontSize="14"/>
                            <TextBlock Style="{StaticResource BtnLabel}" Text="Hilfe"/>
                        </StackPanel>
                    </Button>
                </DockPanel>
                <!-- Gold accent bar -->
                <Border Grid.Row="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#C8922A" Offset="0"/>
                            <GradientStop Color="#E8B84B" Offset="0.5"/>
                            <GradientStop Color="#C8922A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Border>

        <!-- Inhalt -->
        <TabControl Grid.Row="1">
            <TabItem Header="Rohstoffe">
                <views:RohstoffView />
            </TabItem>
            <TabItem Header="Rezepturen">
                <views:RezepturView />
            </TabItem>
        </TabControl>
    </Grid>
</Window>